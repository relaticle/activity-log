he plugin\u002Ffacade.\n    'renderers' => [\n        \u002F\u002F 'email_sent' => \\App\\Timeline\\Renderers\\EmailSentRenderer::class,\n    ],\n\n    'cache' => [\n        'store'       => null,           \u002F\u002F null = default cache store\n        'ttl_seconds' => 0,              \u002F\u002F 0 = no caching (use ->cached() per call)\n        'key_prefix'  => 'activity-log',\n    ],\n];\n","php","",[98,99,100,109,120,126,149,156,162,168,185,190,196,211,216,222,236,255,271,288,306,312,317,323,395,400,406,420,426,431,436,450,469,489,511,516],"code",{"__ignoreMap":96},[101,102,105],"span",{"class":103,"line":104},"line",1,[101,106,108],{"class":107},"sHwdD","\u002F\u002F config\u002Factivity-log.php\n",[101,110,112,116],{"class":103,"line":111},2,[101,113,115],{"class":114},"s7zQu","return",[101,117,119],{"class":118},"sMK4o"," [\n",[101,121,123],{"class":103,"line":122},3,[101,124,125],{"class":107},"    \u002F\u002F Default page size when ->perPage() isn't called.\n",[101,127,129,132,136,139,142,146],{"class":103,"line":128},4,[101,130,131],{"class":118},"    '",[101,133,135],{"class":134},"sfazB","default_per_page",[101,137,138],{"class":118},"'",[101,140,141],{"class":118}," =>",[101,143,145],{"class":144},"sbssI"," 20",[101,147,148],{"class":118},",\n",[101,150,152],{"class":103,"line":151},5,[101,153,155],{"emptyLinePlaceholder":154},true,"\n",[101,157,159],{"class":103,"line":158},6,[101,160,161],{"class":107},"    \u002F\u002F Per-source over-fetch buffer: cap = perPage * (page + buffer).\n",[101,163,165],{"class":103,"line":164},7,[101,166,167],{"class":107},"    \u002F\u002F Higher = safer dedup\u002Ffiltering at higher pages; more DB work.\n",[101,169,171,173,176,178,180,183],{"class":103,"line":170},8,[101,172,131],{"class":118},[101,174,175],{"class":134},"pagination_buffer",[101,177,138],{"class":118},[101,179,141],{"class":118},[101,181,182],{"class":144}," 2",[101,184,148],{"class":118},[101,186,188],{"class":103,"line":187},9,[101,189,155],{"emp