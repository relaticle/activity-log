losure>","). There is ",[214,990,991],{},"no \"plugin > facade > config\" priority"," — whichever channel registers last for a given key wins.",[117,994,995],{},"The boot order in practice:",[144,997,998,1007,1014],{},[147,999,1000,1003,1004,1006],{},[121,1001,1002],{},"ActivityLogServiceProvider::packageBooted()"," registers the built-in ",[121,1005,171],{}," type renderer.",[147,1008,1009,1010,1013],{},"The plugin's ",[121,1011,1012],{},"register(Panel)"," runs when the panel boots, applying its renderers.",[147,1015,1016,1017,1019],{},"The facade can be called from anywhere (a service provider's ",[121,1018,798],{},", middleware, runtime code).",[117,1021,1022,1023,131],{},"So the actual rule is ",[214,1024,1025],{},"last registration wins",[767,1027,1030,1031,172,1034,1037,1038,131],{"color":1028,"icon":1029},"info","i-lucide-lightbulb","A clean split that avoids surprises: register ",[214,1032,1033],{},"stable defaults via config",[214,1035,1036],{},"panel-specific overrides via the plugin",", and ",[214,1039,1040],{},"runtime\u002Fconditional overrides via the facade",[133,1042,198,1044,202],{"id":1043},"replacing-the-built-in-activity_log-renderer",[121,1045,201],{},[117,1047,1048,1049,1051,1052,1054],{},"The service provider auto-registers ",[121,1050,190],{}," for the ",[121,1053,171],{}," type. To replace it wholesale — say, to redact sensitive fields, change the diff format, or embed approval buttons — register your own class for the same type key.",[223,1056,1058],{"className":225,"code":1057,"language":227,"meta":228,"style":228},"use Relaticle\\ActivityLog\\Filament\\ActivityLogPlugin;\n\nActivityLogPlugin::make()->renderers([\n    'activity_log' => \\App\\Timeline\\Renderers\\AuditedActivityLogRenderer::class,\n]);\n",[121,1059,1060,1080,1084,1098,1131],{"__ignoreMap":228},[232,1061,1062,1064,1066,1068,1070,1072,1074,1076,1078],{"class":234,"line":235},[232,1063,239],{"class":238},[232,1065,243],{"class":242},[232,1067,247],{"class":246},[232,1069,250