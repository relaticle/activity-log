: 2);\n\n$total = $record->timeline()->fromActivityLog()->count();\n",[121,731,732,762,766,816,820],{"__ignoreMap":146},[150,733,734,736,739,742,745,747,749,751,753,756,758,760],{"class":152,"line":153},[150,735,157],{"class":156},[150,737,738],{"class":160},"entries ",[150,740,741],{"class":156},"=",[150,743,744],{"class":156}," $",[150,746,161],{"class":160},[150,748,164],{"class":156},[150,750,168],{"class":167},[150,752,189],{"class":156},[150,754,755],{"class":167},"fromActivityLog",[150,757,189],{"class":156},[150,759,300],{"class":167},[150,761,303],{"class":156},[150,763,764],{"class":152,"line":174},[150,765,466],{"emptyLinePlaceholder":465},[150,767,768,770,773,775,777,779,781,783,785,787,789,792,794,798,800,804,806,809,811,814],{"class":152,"line":204},[150,769,157],{"class":156},[150,771,772],{"class":160},"page ",[150,774,741],{"class":156},[150,776,744],{"class":156},[150,778,161],{"class":160},[150,780,164],{"class":156},[150,782,168],{"class":167},[150,784,189],{"class":156},[150,786,755],{"class":167},[150,788,189],{"class":156},[150,790,791],{"class":167},"paginate",[150,793,183],{"class":156},[150,795,797],{"class":796},"sBMFI","perPage",[150,799,541],{"class":156},[150,801,803],{"class":802},"sbssI"," 25",[150,805,263],{"class":156},[150,807,808],{"class":796}," page",[150,810,541],{"class":156},[150,812,813],{"class":802}," 2",[150,815,632],{"class":156},[150,817,818],{"class":152,"line":227},[150,819,466],{"emptyLinePlaceholder":465},[150,821,822,824,827,829,831,833,835,837,839,841,843,846],{"class":152,"line":246},[150,823,157],{"class":156},[150,825,826],{"class":160},"total ",[150,828,741],{"class":156},[150,830,744],{"class":156},[150,832,161],{"class":160},[150,834,164],{"class":156},[150,836,168],{"class":167},[150,838,189],{"class":156},[150,840,755],{"class":167},[150,842,189],{"class":156},[150,844,845],{"class":167},"count",[150,847,303],{"class":156},[392,849,852,853,856],{"color":850,"icon":851},"info","i-lucide-lightbulb","For in-Filament rendering you almost never call these directly — the infolist component, relation manager, and action all mount the Livewire timeline component, which calls ",[121,854,855],{},"paginate()"," for you. Direct calls are useful for tests, queue workers, exports, and other non-UI consumers.",[133,858,860,861],{"id":859},"trait-helper-paginatetimeline","Trait helper: ",[121,862,863],{},"paginateTimeline()",[117,865,866,867,870,871,874,875,878,879,882],{},"The ",[121,868,869],{},"Relaticle\\ActivityLog\\Concerns\\InteractsWithTimeline"," trait exposes ",[121,872,873],{},"paginateTimeline(?int $perPage = null, int $page = 1)"," as a pass-through to ",[121,876,877],{},"$this->timeline()->paginate(...)",". It's required by the ",[121,880,881],{},"Relaticle\\ActivityLog\\Contracts\\HasTimeline"," interface, so consumers can paginate without going through the builder explicitly:",[141,884,886],{"className":143,"code":885,"language":145,"meta":146,"style":146},"$page = $opportunity->paginateTimeline(perPage: 20, page: 1);\n",[121,887,888],{"__ignoreMap":146},[150,889,890,892,894,896,898,901,903,906,908,910,912,915,917,919,921,924],{"class":152,"line":153},[150,891,157],{"class":156},[150,893,772],{"class":160},[150,895,741],{"class":156},[150,897,744],{"class":156},[150,899,900],{"class":160},"opportunity",[150,902,164],{"class":156},[150,904,905],{"class":167},"paginateTimeline",[150,907,183],{"class":156},[150,909,797],{"class":796},[150,911,541],{"class":156},[150,913,914],{"class":802}," 20",[150,916,263],{"class":156},[150,918,808],{"class":796},[150,920,541],{"class":156},[150,922,923],{"class":802}," 1",[150,925,632],{"class":156},[117,927,928,929,932,933,935],{},"This is the entry point the Livewire timeline component uses internally. Override ",[121,930,931],{},"timeline()"," on the model to customize source registration once and have every caller — including ",[121,934,863],{}," — pick it up.",[133,937,939],{"id":938},"pagination-buffer-mechanics","Pagination buffer mechanics",[117,941,942,943,946,947,950],{},"Pagination uses an over-fetch strategy controlled by the ",[121,944,945],{},"pagination_buffer"," config key (default ",[121,948,949],{},"2","):",[141,952,957],{"className":953,"code":955,"language":956,"meta":146},[954],"language-text","cap = perPage × (page + buffer)\n","text",[121,958,955],{"__ignoreMap":146},[117,960,961,962,965,966,969],{},"Each source is asked for at most ",[121,963,964],{},"cap"," entries via ",[121,967,968],{},"Window::cap",". After dedup and post-source filtering drop entries, the remaining set is sliced down to the requested page. Over-fetching keeps deeper pages from coming up short when entries are removed during the pipeline.",[117,971,972],{},[397,973,974],{},"Trade-off:",[976,977,978,986],"ul",{},[979,980,981,982,985],"li",{},"Higher ",[121,983,984],{},"buffer"," — more memory, more rows scanned per source, but exact pagination at deep pages even when sources collide heavily.",[979,987,988,989,991,992,994],{},"Lower ",[121,990,984],{}," — less memory, fewer rows scanned, but risk of a deep page returning fewer than ",[121,993,797],{}," entries when dedup removes a lot.",[117,996,997,1000,1001,1004,1005,1007],{},[397,998,999],{},"When to lower it:"," sources rarely collide (no overlapping ",[121,1002,1003],{},"dedupKey","s) and your filters are permissive. The default ",[121,1006,949],{}," is overkill for single-source timelines.",[117,1009,1010,1013],{},[397,1011,1012],{},"When to raise it:"," sources overlap heavily — for example, a custom source that re-emits events also covered by spatie activity log — and you need exact page sizes at high page numbers.",[117,1015,1016,1017,1019],{},"See ",[126,1018,63],{"href":63}," for the config key.",[1021,1022,1023],"style",{},"html pre.shiki code .sMK4o, html code.shiki .sMK4o{--shiki-light:#39ADB5;--shiki-default:#89DDFF;--shiki-dark:#89DDFF}html pre.shiki code .sTEyZ, html code.shiki .sTEyZ{--shiki-light:#90A4AE;--shiki-default:#EEFFFF;--sh