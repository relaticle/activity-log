[{"data":1,"prerenderedAt":237},["ShallowReactive",2],{"navigation_docs":3,"-essentials-troubleshooting":60,"-essentials-troubleshooting-surround":232},[4,15,45],{"title":5,"icon":6,"path":7,"stem":8,"children":9,"page":6},"Getting Started",false,"\u002Fgetting-started","1.getting-started",[10],{"title":11,"path":12,"stem":13,"icon":14},"Installation","\u002Fgetting-started\u002Finstallation","1.getting-started\u002F1.installation","i-lucide-download",{"title":16,"path":17,"stem":18,"children":19,"page":6},"Essentials","\u002Fessentials","2.essentials",[20,25,30,35,40],{"title":21,"path":22,"stem":23,"icon":24},"Integration Patterns","\u002Fessentials\u002Fintegration-patterns","2.essentials\u002F1.integration-patterns","i-lucide-layers",{"title":26,"path":27,"stem":28,"icon":29},"Customization","\u002Fessentials\u002Fcustomization","2.essentials\u002F2.customization","i-lucide-palette",{"title":31,"path":32,"stem":33,"icon":34},"Database Schema","\u002Fessentials\u002Fdatabase-schema","2.essentials\u002F3.database-schema","i-lucide-database",{"title":36,"path":37,"stem":38,"icon":39},"API Reference","\u002Fessentials\u002Fapi-reference","2.essentials\u002F4.api-reference","i-lucide-code-2",{"title":41,"path":42,"stem":43,"icon":44},"Troubleshooting","\u002Fessentials\u002Ftroubleshooting","2.essentials\u002F5.troubleshooting","i-lucide-wrench",{"title":46,"path":47,"stem":48,"children":49,"page":6},"Community","\u002Fcommunity","3.community",[50,55],{"title":51,"path":52,"stem":53,"icon":54},"Contributing","\u002Fcommunity\u002Fcontributing","3.community\u002F1.contributing","i-lucide-heart-handshake",{"title":56,"path":57,"stem":58,"icon":59},"License","\u002Fcommunity\u002Flicense","3.community\u002F2.license","i-lucide-scale",{"id":61,"title":41,"body":62,"description":225,"extension":226,"links":227,"meta":228,"navigation":229,"path":42,"seo":230,"stem":43,"__hash__":231},"docs\u002F2.essentials\u002F5.troubleshooting.md",{"type":63,"value":64,"toc":216},"minimark",[65,71,76,120,124,137,141,149,172,176,187,202,206],[66,67,70],"callout",{"color":68,"icon":69},"warning","i-lucide-construction","This page will grow with FAQ entries as users report issues. Start here, then open a discussion on GitHub if your problem isn't covered.",[72,73,75],"h2",{"id":74},"performance","Performance",[77,78,79,92,103,109],"ul",{},[80,81,82,83,87,88,91],"li",{},"Every source batch-loads; no N+1 in the core path. Use ",[84,85,86],"code",{},"->with([...])"," on ",[84,89,90],{},"RelatedModelSource"," if your renderer\u002Ftitle resolver reads relations.",[80,93,94,95,98,99,102],{},"Pagination over-fetches by ",[84,96,97],{},"perPage × (page + pagination_buffer)"," per source so dedup\u002Ffiltering stays correct at higher pages. Tune ",[84,100,101],{},"pagination_buffer"," if your sources rarely collide.",[80,104,105,108],{},[84,106,107],{},"get()"," is capped at 10 000 entries. For unbounded history, paginate instead.",[80,110,111,112,115,116,119],{},"Add the ",[84,113,114],{},"['subject_type', 'subject_id', 'created_at']"," compound index on ",[84,117,118],{},"activity_log",".",[72,121,123],{"id":122},"timeline-looks-unstyled-in-production","Timeline looks unstyled in production",[125,126,127,128,131,132,119],"p",{},"The plugin's Blade views use Tailwind utilities. If you see plain HTML, your panel theme isn't compiling the plugin's views. Add the ",[84,129,130],{},"@source"," directive described in ",[133,134,136],"a",{"href":135},"\u002Fessentials\u002Fcustomization#tailwind-theme-integration","Customization → Tailwind theme integration",[72,138,140],{"id":139},"custom-renderer-isnt-picked-up","Custom renderer isn't picked up",[125,142,143,144,148],{},"Check the resolution order in ",[133,145,147],{"href":146},"\u002Fessentials\u002Fcustomization#renderer-resolution-order","Customization → Renderer resolution order",". Most often:",[77,150,151,162,169],{},[80,152,153,154,157,158,161],{},"The binding key is the ",[84,155,156],{},"event"," string, not a class name - verify ",[84,159,160],{},"$entry->event"," matches.",[80,163,164,165,168],{},"An entry-level ",[84,166,167],{},"$entry->renderer"," override beats registered bindings.",[80,170,171],{},"Config-file bindings merge with plugin\u002Ffacade bindings; duplicates resolve in plugin-then-config order.",[72,173,175],{"id":174},"duplicate-entries-appearing","Duplicate entries appearing",[125,177,178,179,182,183,186],{},"Dedup uses ",[84,180,181],{},"dedupKey"," + ",[84,184,185],{},"sourcePriority",". If two sources emit the same logical event with different keys, they won't collapse. Either:",[77,188,189,199],{},[80,190,191,192,194,195,198],{},"Align ",[84,193,181],{}," on both sources (use ",[84,196,197],{},"dedupKeyUsing()"," on the builder), or",[80,200,201],{},"Raise the preferred source's priority so the loser is dropped.",[72,203,205],{"id":204},"questions-not-covered-here","Questions not covered here",[125,207,208,209,215],{},"Open a ",[133,210,214],{"href":211,"rel":212},"https:\u002F\u002Fgithub.com\u002Frelaticle\u002Factivity-log\u002Fdiscussions",[213],"nofollow","GitHub discussion"," - the maintainers and community triage there.",{"title":217,"searchDepth":218,"depth":218,"links":219},"",2,[220,221,222,223,224],{"id":74,"depth":218,"text":75},{"id":122,"depth":218,"text":123},{"id":139,"depth":218,"text":140},{"id":174,"depth":218,"text":175},{"id":204,"depth":218,"text":205},"Common pitfalls, performance tuning, and debugging tips.","md",null,{},{"icon":44},{"title":41,"description":225},"FiLgvNJdjKFbg3M1k-2gux0oGP4s5uHABEOApnDykzk",[233,235],{"title":36,"path":37,"stem":38,"description":234,"icon":39,"children":-1},"Components, builder refinements, config keys, and caching API.",{"title":51,"path":52,"stem":53,"description":236,"icon":54,"children":-1},"How to contribute to Activity Log",1776783913415]