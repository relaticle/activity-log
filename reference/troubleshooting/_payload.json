ity\u002F1.contributing","i-lucide-heart-handshake",{"title":71,"path":72,"stem":73,"icon":74},"License","\u002Fcommunity\u002Flicense","4.community\u002F2.license","i-lucide-scale",{"title":66,"path":67,"stem":76,"icon":69},"5.community\u002F1.contributing",{"title":71,"path":72,"stem":78,"icon":74},"5.community\u002F2.license",{"id":80,"title":56,"body":81,"description":244,"extension":245,"links":246,"meta":247,"navigation":248,"path":57,"seo":249,"stem":58,"__hash__":250},"docs\u002F3.reference\u002F2.troubleshooting.md",{"type":82,"value":83,"toc":235},"minimark",[84,90,95,139,143,156,160,168,191,195,206,221,225],[85,86,89],"callout",{"color":87,"icon":88},"warning","i-lucide-construction","This page will grow with FAQ entries as users report issues. Start here, then open a discussion on GitHub if your problem isn't covered.",[91,92,94],"h2",{"id":93},"performance","Performance",[96,97,98,111,122,128],"ul",{},[99,100,101,102,106,107,110],"li",{},"Every source batch-loads; no N+1 in the core path. Use ",[103,104,105],"code",{},"->with([...])"," on ",[103,108,109],{},"RelatedModelSource"," if your renderer\u002Ftitle resolver reads relations.",[99,112,113,114,117,118,121],{},"Pagination over-fetches by ",[103,115,116],{},"perPage × (page + pagination_buffer)"," per source so dedup\u002Ffiltering stays correct at higher pages. Tune ",[103,119,120],{},"pagination_buffer"," if your sources rarely collide.",[99,123,124,127],{},[103,125,126],{},"get()"," is capped at 10 000 entries. For unbounded history, paginate instead.",[99,129,130,131,134,135,138],{},"Add the ",[103,132,133],{},"['subject_type', 'subject_id', 'created_at']"," compound index on ",[103,136,137],{},"activity_log",".",[91,140,142],{"id":141},"timeline-looks-unstyled-in-production","Timeline looks unstyled in production",[144,145,146,147,150,151,138],"p",{},"The plugin's Blade views use Tailwind utilities. If you see plain HTML, your panel theme isn't compiling the plugin's views. Add the ",[103,148,149],{},"@source"," directive described in ",[152,153,155],"a",{"href":154},"\u002Fessentials\u002Fcustomization#tailwind-theme-integration","Customization → Tailwind theme integration",[91,157,159],{"id":158},"custom-renderer-isnt-picked-up","Custom renderer isn't picked up",[144,161,162,163,167],{},"Check the resolution order in ",[152,164,166],{"href":165},"\u002Fessentials\u002Fcustomization#renderer-resolution-order","Customization → Renderer resolution order",". Most often:",[96,169,170,181,188],{},[99,171,172,173,176,177,180],{},"The binding key is the ",[103,174,175],{},"event"," string, not a class name - verify ",[103,178,179],{},"$entry->event"," matches.",[99,182,183,184,187],{},"An entry-level ",[103,185,186],{},"$entry->renderer"," override beats registered bindings.",[99,189,190],{},"Config-file bindings merge with plugin\u002Ffacade bindings; duplicates resolve in plugin-then-config order.",[91,192,194],{"id":193},"duplicate-entries-appearing","Duplicate entries appearing",[144,196,197,198,201,202,205],{},"Dedup uses ",[103,199,200],{},"dedupKey"," + ",[103,203,204],{},"sourcePriority",". If two sources emit the same logical event with different keys, they won't collapse. Either:",[96,207,208,218],{},[99,209,210,211,213,214,217],{},"Align ",[103,212,200],{}," on both sources (use ",[103,215,216],{},"dedupKeyUsing()"," on the builder), or",[99,219,220],{},"Raise the preferred source's priority so the loser is dropped.",[91,222,224],{"id":223},"questions-not-covered-here","Questions not covered here",[144,226,227,228,234],{},"Open a ",[152,229,233],{"href":230,"rel":231},"https:\u002F\u002Fgithub.com\u002Frelaticle\u002Factivity-log\u002Fdiscussions",[232],"nofollow","GitHub discussion"," - the maintainers and community triage there.",{"title":236,"searchDepth":237,"depth":237,"links":238},"",2,[239,240,241,242,243],{"id":93,"depth":237,"text":94},{"id":141,"depth":237,"text":142},{"id":158,"depth":237,"text":159},{"id":193,"depth":237,"text":194},{"id"